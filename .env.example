# ENVIRONMENT
ENVIRONMENT=development
DEBUG=True

# DATABASE
POSTGRES_DB=jardinsecreto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/jardinsecreto

# REDIS
REDIS_URL=redis://redis:6379

# API KEYS (Add your keys here)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DATA PROVIDERS
POLYGON_API_KEY=your_polygon_key_here
TWELVE_DATA_API_KEY=your_twelve_data_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# BROKERS
INTERACTIVE_BROKERS_ACCOUNT=your_ib_account
OANDA_ACCOUNT_ID=your_oanda_account
OANDA_API_KEY=your_oanda_key

# JWT
JWT_SECRET_KEY=your_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# GRAFANA
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json

# FEATURES
ENABLE_AI_ANALYSIS=true
ENABLE_ALERTS=true
ENABLE_BACKTESTING=false

# MARKET DATA
MARKET_DATA_UPDATE_INTERVAL=60  # seconds
MACRO_ANALYSIS_INTERVAL=300    # 5 minutes
CORRELATION_UPDATE_INTERVAL=3600  # 1 hour

# PERFORMANCE
DATABASE_CONNECTION_POOL_SIZE=20
REDIS_MAX_CONNECTIONS=50
MAX_WORKERS=4
